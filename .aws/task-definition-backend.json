{
  "family": "sgp-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "sgp-backend",
      "image": "PLACEHOLDER",
      "essential": true,
      "portMappings": [
        { "containerPort": 3001, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3001" }
      ],
      "secrets": [
        { "name": "POSTGRES_HOST",     "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/sgp/POSTGRES_HOST" },
        { "name": "POSTGRES_PORT",     "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/sgp/POSTGRES_PORT" },
        { "name": "POSTGRES_USER",     "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/sgp/POSTGRES_USER" },
        { "name": "POSTGRES_PASSWORD", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/sgp/POSTGRES_PASSWORD" },
        { "name": "POSTGRES_DB",       "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/sgp/POSTGRES_DB" },
        { "name": "REDIS_HOST",        "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/sgp/REDIS_HOST" },
        { "name": "REDIS_PORT",        "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/sgp/REDIS_PORT" },
        { "name": "CORS_ORIGIN",       "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/sgp/CORS_ORIGIN" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:3001/saude || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sgp-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
